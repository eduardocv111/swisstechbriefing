generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String
  date        DateTime
  authorName  String
  authorRole  String?
  sourcesJson String
  imageUrl    String?
  expertQuote  String?
  keyFactsJson String?
  isVerified   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  translations ArticleTranslation[]

  @@index([category])
  @@index([createdAt])
}

model ArticleTranslation {
  id              String   @id @default(cuid())
  articleId       String
  locale          String
  title           String
  excerpt         String
  contentHtml     String
  metaTitle       String?
  metaDescription String?
  updatedAt       DateTime @updatedAt
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale])
}

model NewsletterSubscription {
  id         String   @id @default(cuid())
  email      String
  source     String
  leadMagnet String?
  createdAt  DateTime @default(now())
  @@index([email])
}

model MarketSnapshot {
  id          Int      @id @default(autoincrement())
  createdAt   String   @map("created_at")
  payloadJson String   @map("payload_json")
  @@map("market_snapshots")
}

model MacroSnapshot {
  id          Int      @id @default(autoincrement())
  createdAt   String   @map("created_at")
  payloadJson String   @map("payload_json")
  @@map("macro_snapshots")
}

model SnbSnapshot {
  id          Int      @id @default(autoincrement())
  createdAt   String   @map("created_at")
  payloadJson String   @map("payload_json")
  @@map("snb_snapshots")
}

model SwissOpenDataSnapshot {
  id          Int      @id @default(autoincrement())
  createdAt   String   @map("created_at")
  payloadJson String   @map("payload_json")
  @@map("swiss_open_data_snapshots")
}
