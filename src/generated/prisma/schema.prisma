generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  contentHtml String
  category    String
  date        DateTime
  authorName  String
  authorRole  String?
  sourcesJson String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscription {
  id         String   @id @default(cuid())
  email      String
  source     String // e.g., 'dedicated_page', 'inline_card'
  leadMagnet String? // e.g., 'ai_report_pdf'
  createdAt  DateTime @default(now())

  @@index([email])
}
